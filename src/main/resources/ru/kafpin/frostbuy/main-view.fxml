<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.control.ScrollPane?>
<BorderPane prefHeight="600.0" prefWidth="1000.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ru.kafpin.frostbuy.MainController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" styleClass="top-panel" BorderPane.alignment="CENTER">
         <Label styleClass="logo-text" text="FROST❄BUY | АРМ Менеджера">
            <HBox.margin>
               <Insets left="20.0" />
            </HBox.margin>
         </Label>
         <Region HBox.hgrow="ALWAYS" />
         <Button mnemonicParsing="false" styleClass="button" text="Выйти из системы">
            <HBox.margin>
               <Insets right="20.0" />
            </HBox.margin>
         </Button>
      </HBox>
   </top>
   <center>
      <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
         <tabs>
            <!-- Вкладка 1: Управление играми -->
            <Tab text="Каталог игр">
               <VBox spacing="10.0">
                  <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                  <HBox spacing="10.0">
                     <Button mnemonicParsing="false" styleClass="button" text="Добавить игру" />
                     <Button mnemonicParsing="false" styleClass="button" text="Редактировать" />
                     <Button mnemonicParsing="false" styleClass="button" text="Удалить" />
                  </HBox>
                  <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="edge-to-edge" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                     <FlowPane fx:id="gamesFlowPane" hgap="20.0" vgap="20.0" style="-fx-background-color: #1b2838;">
                        <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                     </FlowPane>
                  </ScrollPane>
               </VBox>
            </Tab>

            <!-- Вкладка 2: Учет ключей и физических копий -->
            <Tab text="Склад и Ключи">
               <VBox spacing="10.0">
                  <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                  <Label text="Управление инвентарем для выбранной игры" textFill="WHITE" />
                  <!-- Здесь потом добавим две таблицы: ключи и диски -->
               </VBox>
            </Tab>

            <!-- Вкладка 3: Обработка заказов -->
            <Tab text="Заказы">
               <VBox spacing="10.0">
                  <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
                  <HBox spacing="10.0">
                     <Button mnemonicParsing="false" styleClass="button" text="Изменить статус заказа" />
                  </HBox>
                  <TableView prefHeight="450.0" prefWidth="980.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn text="№ Заказа" prefWidth="100" />
                        <TableColumn text="Покупатель" prefWidth="150" />
                        <TableColumn text="Тип (Цифр/Физ)" prefWidth="120" />
                        <TableColumn text="Статус" prefWidth="150" />
                        <TableColumn text="Сумма" prefWidth="100" />
                     </columns>
                  </TableView>
               </VBox>
            </Tab>

            <!-- Вкладка 4: Статистика -->
            <Tab text="Статистика">
               <VBox alignment="CENTER" spacing="10.0">
                  <Label text="Здесь будут графики продаж" textFill="WHITE" />
               </VBox>
            </Tab>
         </tabs>
      </TabPane>
   </center>
</BorderPane>